{
  "$defs": {
    "CertSection": {
      "properties": {
        "title": {
          "default": "Professional Certificates",
          "title": "Title",
          "type": "string"
        },
        "certifications": {
          "items": {
            "$ref": "#/$defs/CertSubsection"
          },
          "title": "Certifications",
          "type": "array"
        }
      },
      "required": [
        "certifications"
      ],
      "title": "CertSection",
      "type": "object"
    },
    "CertSubsection": {
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "issuer": {
          "title": "Issuer",
          "type": "string"
        },
        "link": {
          "anyOf": [
            {
              "$ref": "#/$defs/Link"
            },
            {
              "type": "null"
            }
          ]
        },
        "start_date": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Start Date"
        },
        "end_date": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "End Date"
        },
        "bullet_points": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "title": "Bullet Points"
        }
      },
      "required": [
        "name",
        "issuer",
        "link",
        "start_date",
        "end_date",
        "bullet_points"
      ],
      "title": "CertSubsection",
      "type": "object"
    },
    "EducationSection": {
      "properties": {
        "title": {
          "default": "Education",
          "title": "Title",
          "type": "string"
        },
        "educations": {
          "items": {
            "$ref": "#/$defs/EducationSubsection"
          },
          "title": "Educations",
          "type": "array"
        }
      },
      "required": [
        "educations"
      ],
      "title": "EducationSection",
      "type": "object"
    },
    "EducationSubsection": {
      "properties": {
        "institution": {
          "title": "Institution",
          "type": "string"
        },
        "degree": {
          "title": "Degree",
          "type": "string"
        },
        "location": {
          "title": "Location",
          "type": "string"
        },
        "start_date": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Start Date"
        },
        "end_date": {
          "title": "End Date",
          "type": "string"
        },
        "relevant_coursework": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": [],
          "title": "Relevant Coursework"
        },
        "gpa": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Gpa"
        }
      },
      "required": [
        "institution",
        "degree",
        "location",
        "start_date",
        "end_date"
      ],
      "title": "EducationSubsection",
      "type": "object"
    },
    "ExperienceSection": {
      "properties": {
        "title": {
          "default": "Work Experience",
          "title": "Title",
          "type": "string"
        },
        "experiences": {
          "items": {
            "$ref": "#/$defs/ExperienceSubsection"
          },
          "title": "Experiences",
          "type": "array"
        }
      },
      "required": [
        "experiences"
      ],
      "title": "ExperienceSection",
      "type": "object"
    },
    "ExperienceSubsection": {
      "properties": {
        "position": {
          "title": "Position",
          "type": "string"
        },
        "company": {
          "title": "Company",
          "type": "string"
        },
        "location": {
          "default": "Remote",
          "title": "Location",
          "type": "string"
        },
        "start_date": {
          "title": "Start Date",
          "type": "string"
        },
        "end_date": {
          "default": "Present",
          "title": "End Date",
          "type": "string"
        },
        "bullet_points": {
          "items": {
            "type": "string"
          },
          "title": "Bullet Points",
          "type": "array"
        }
      },
      "required": [
        "position",
        "company",
        "start_date",
        "bullet_points"
      ],
      "title": "ExperienceSubsection",
      "type": "object"
    },
    "Link": {
      "properties": {
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "url": {
          "format": "uri",
          "maxLength": 2083,
          "minLength": 1,
          "title": "Url",
          "type": "string"
        }
      },
      "required": [
        "url"
      ],
      "title": "Link",
      "type": "object"
    },
    "ProjectSection": {
      "properties": {
        "title": {
          "default": "Projects",
          "title": "Title",
          "type": "string"
        },
        "projects": {
          "items": {
            "$ref": "#/$defs/ProjectSubsection"
          },
          "title": "Projects",
          "type": "array"
        }
      },
      "required": [
        "projects"
      ],
      "title": "ProjectSection",
      "type": "object"
    },
    "ProjectSubsection": {
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "secondary_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Secondary Name"
        },
        "link": {
          "anyOf": [
            {
              "$ref": "#/$defs/Link"
            },
            {
              "type": "null"
            }
          ]
        },
        "skills": {
          "items": {
            "type": "string"
          },
          "title": "Skills",
          "type": "array"
        },
        "bullet_points": {
          "items": {
            "type": "string"
          },
          "title": "Bullet Points",
          "type": "array"
        }
      },
      "required": [
        "name",
        "secondary_name",
        "link",
        "skills",
        "bullet_points"
      ],
      "title": "ProjectSubsection",
      "type": "object"
    },
    "ResumeContent": {
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "phone_number": {
          "title": "Phone Number",
          "type": "string"
        },
        "email": {
          "format": "email",
          "title": "Email",
          "type": "string"
        },
        "socials": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/Link"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": [],
          "title": "Socials"
        },
        "section_order": {
          "default": [
            "education",
            "skills",
            "experience",
            "projects",
            "certs"
          ],
          "items": {
            "$ref": "#/$defs/Section"
          },
          "title": "Section Order",
          "type": "array"
        },
        "education": {
          "anyOf": [
            {
              "$ref": "#/$defs/EducationSection"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "skills": {
          "anyOf": [
            {
              "$ref": "#/$defs/SkillSection"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "experience": {
          "anyOf": [
            {
              "$ref": "#/$defs/ExperienceSection"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "projects": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProjectSection"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "certs": {
          "anyOf": [
            {
              "$ref": "#/$defs/CertSection"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "name",
        "phone_number",
        "email"
      ],
      "title": "ResumeContent",
      "type": "object"
    },
    "Section": {
      "enum": [
        "education",
        "skills",
        "experience",
        "projects",
        "certs"
      ],
      "title": "Section",
      "type": "string"
    },
    "SkillList": {
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "skills": {
          "items": {
            "type": "string"
          },
          "title": "Skills",
          "type": "array"
        }
      },
      "required": [
        "name",
        "skills"
      ],
      "title": "SkillList",
      "type": "object"
    },
    "SkillSection": {
      "properties": {
        "title": {
          "default": "Technical Skills",
          "title": "Title",
          "type": "string"
        },
        "skill_lists": {
          "items": {
            "$ref": "#/$defs/SkillList"
          },
          "title": "Skill Lists",
          "type": "array"
        }
      },
      "required": [
        "skill_lists"
      ],
      "title": "SkillSection",
      "type": "object"
    }
  },
  "properties": {
    "resume": {
      "$ref": "#/$defs/ResumeContent"
    }
  },
  "required": [
    "resume"
  ],
  "title": "Resume",
  "type": "object"
}
